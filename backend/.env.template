# Fortress Optimizer - Environment Configuration Template
# Copy this to .env and fill in production values

# ============================================================================
# Server Configuration
# ============================================================================
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development  # Set to 'production' in production
DEBUG=true  # Set to false in production

# ============================================================================
# JWT Configuration
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=sqlite:///./fortress.db  # For development
# DATABASE_URL=postgresql://user:password@localhost:5432/fortress_db  # For production

# ============================================================================
# Security Configuration
# ============================================================================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]  # Add website URLs
API_KEY_LENGTH=32
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# Extension Configuration
# ============================================================================
EXTENSION_API_KEY_EXPIRATION_DAYS=365
EXTENSION_MAX_DEVICES_PER_USER=10
EXTENSION_SYNC_INTERVAL_MINUTES=5

# ============================================================================
# Email Configuration (for future use)
# ============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@fortress-optimizer.com

# ============================================================================
# AWS Configuration (for production deployment)
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_NAME=fortress-optimizer-backups

# ============================================================================
# Analytics & Monitoring
# ============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
SENTRY_DSN=  # Leave empty for development

# ============================================================================
# API Documentation
# ============================================================================
DOCS_URL=/docs
REDOC_URL=/redoc

# ============================================================================
# Production Security Hardening
# ============================================================================
# Set these in production:
# - ENVIRONMENT=production
# - DEBUG=false
# - Use a proper database (PostgreSQL)
# - Use a strong JWT_SECRET
# - Configure HTTPS/TLS
# - Set proper CORS_ORIGINS
# - Enable monitoring/logging
