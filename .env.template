# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# JWT Configuration
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================================
# Stripe Configuration (for payment processing)
# ============================================================================
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret

# ============================================================================
# Database Configuration (PostgreSQL - optional for production)
# ============================================================================
# For development, the system uses in-memory storage
# For production, uncomment and configure:
# DATABASE_URL=postgresql://user:password@localhost:5432/fortress_optimizer
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=10

# ============================================================================
# Email Configuration (SendGrid or similar)
# ============================================================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
SMTP_FROM=noreply@fortress-optimizer.com

# ============================================================================
# AWS Configuration (for deployed backend)
# ============================================================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_COGNITO_USER_POOL_ID=your-cognito-pool-id (optional: for user management)

# ============================================================================
# API Configuration
# ============================================================================
API_KEY_PREFIX=sk_
API_BASE_URL=https://api.fortress-optimizer.com
FRONTEND_URL=https://fortress-optimizer.com

# ============================================================================
# Rate Limiting & Tier Configuration
# ============================================================================
# These values are configured in the code, but can be overridden here
FREE_TIER_MONTHLY_LIMIT=50000
FREE_TIER_REQUESTS_PER_MINUTE=10

PRO_TIER_MONTHLY_LIMIT=500000
PRO_TIER_REQUESTS_PER_MINUTE=100

TEAM_TIER_MONTHLY_LIMIT=50000000
TEAM_TIER_REQUESTS_PER_MINUTE=1000

# ============================================================================
# Development / Production Flags
# ============================================================================
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=info

# ============================================================================
# CORS Configuration
# ============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://fortress-optimizer.com

# ============================================================================
# Security
# ============================================================================
# Hash algorithm for password hashing
PASSWORD_HASH_ALGORITHM=pbkdf2_sha256
PASSWORD_HASH_ITERATIONS=100000

# API key hashing
API_KEY_HASH_ALGORITHM=sha256

# ============================================================================
# Instructions
# ============================================================================
# 1. Copy this file: cp .env.template .env
# 2. Generate JWT_SECRET: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# 3. Get Stripe keys from: https://dashboard.stripe.com/apikeys
# 4. For production, use strong random values for all secret keys
# 5. Never commit .env file to version control
