    "react-dom": "^18.2.0",
    "axios": "^1.6.0",
    "sqlite3": "^5.1.6",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "typescript": "^5.3.3",
    "tailwindcss": "^3.3.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ]
  }
}
