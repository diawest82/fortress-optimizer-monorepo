{
  "name": "fortress-token-optimizer-desktop",
  "version": "1.0.0",
  "description": "Fortress Token Optimizer - Desktop Application",
  "main": "dist/src/electron/main.js",
  "homepage": "./",
  "author": "Diawest82",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron dist/src/electron/main.js",
    "dev": "NODE_ENV=development npm run start",
    "test": "tsc --noEmit && npx ts-node test_app.ts",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "axios": "1.13.5",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.10.0"
  },
  "build": {
    "appId": "com.fortress-optimizer.desktop",
    "productName": "Fortress Token Optimizer",
    "files": [
      "dist/**/*",
      "src/renderer/index.html",
      "src/renderer/styles.css",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
