// Fortress Operations Council — IMA-Lang Definition
// Phased council: only agents with real work today are active.
// Compile: imalc compile fortress_operations.imal --target all

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE A — Active Now (3 agents with real infrastructure to manage)
// ═══════════════════════════════════════════════════════════════════════════════

agent InfrastructureGuard: Agent<
    domain = infrastructure,
    authority = 0.92,
    decay = halflife(7d),
    recovery = +0.5 on_success,
    specializations = [ecs, rds, alb, ecr, codebuild, cloudwatch]
>

agent SecuritySentinel: Agent<
    domain = security,
    authority = 0.95,
    decay = halflife(30d),
    recovery = +0.5 on_success,
    specializations = [api_keys, rate_limiting, vulnerability_scan, credential_rotation]
>

agent DeploymentAgent: Agent<
    domain = deployment,
    authority = 0.88,
    decay = halflife(14d),
    recovery = +0.4 on_success,
    specializations = [codebuild, ecr, ecs_update, rollback, platform_publish]
>

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE B — Activate on first paying customer
// ═══════════════════════════════════════════════════════════════════════════════

